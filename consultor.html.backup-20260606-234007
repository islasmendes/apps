<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#050506">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>Meu Dia — Gestão Alta Performance</title>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
<style>
  :root {
    --bg: #050506; --bg-soft: #0d0d11; --panel: #111114; --panel-2: #18181d;
    --border: #30313a; --text: #f0f2f7; --text-dim: #a3a9ba; --text-faint: #717889;
    --accent: #4f8cff; --accent-2: #22d3aa; --danger: #ff5d6c; --warn: #ffb74d; --ok: #46d39a;
    --dio-in-bg: #152238; --dio-in-bd: #3d6ec4; --dio-out-bg: #122820; --dio-out-bd: #1f9a72;
    --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --safe-b: env(safe-area-inset-bottom, 0px);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; min-height: 100%; background: var(--bg); color: var(--text); font-family: var(--font); }
  body {
    background:
      radial-gradient(900px 500px at 90% -5%, color-mix(in srgb, var(--accent) 22%, transparent), transparent),
      radial-gradient(700px 400px at -10% 30%, color-mix(in srgb, var(--accent-2) 14%, transparent), transparent),
      var(--bg);
  }
  .app { max-width: 480px; margin: 0 auto; min-height: 100dvh; display: flex; flex-direction: column; }
  .topbar {
    position: sticky; top: 0; z-index: 20; padding: 14px 16px 10px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--panel) 96%, transparent), color-mix(in srgb, var(--panel) 82%, transparent));
    backdrop-filter: blur(14px); border-bottom: 1px solid var(--border);
  }
  .topbar-row { display: flex; align-items: center; gap: 10px; }
  .logo {
    width: 36px; height: 36px; border-radius: 11px; flex: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    display: grid; place-items: center; font-weight: 800; font-size: 15px; color: #fff;
    box-shadow: 0 8px 22px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .top-titles { flex: 1; min-width: 0; }
  .top-titles .t1 { font-weight: 800; font-size: 13.5px; letter-spacing: .15px; line-height: 1.25; }
  .top-titles .t1-sep { color: var(--text-faint); font-weight: 600; margin: 0 2px; }
  .live-pill {
    display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 800;
    text-transform: uppercase; letter-spacing: .4px; padding: 4px 9px; border-radius: 99px;
    border: 1px solid var(--border); background: var(--panel-2); color: var(--text-dim);
  }
  .live-pill.on { border-color: color-mix(in srgb, var(--ok) 50%, var(--border)); color: var(--ok); }
  .live-pill .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  .live-pill.on .dot { animation: pulse 1.8s ease infinite; }
  @keyframes pulse { 0%,100%{opacity:1; transform:scale(1)} 50%{opacity:.45; transform:scale(.85)} }
  .urgency-pill {
    display: none; flex-direction: column; align-items: center; gap: 1px; font-weight: 800;
    font-variant-numeric: tabular-nums; letter-spacing: .3px; padding: 5px 10px; border-radius: 99px;
    background: linear-gradient(135deg, color-mix(in srgb, var(--danger) 28%, #1a0808), color-mix(in srgb, var(--danger) 12%, var(--panel)));
    border: 1px solid color-mix(in srgb, var(--danger) 65%, var(--border)); color: #ff8a94;
    box-shadow: 0 0 18px color-mix(in srgb, var(--danger) 35%, transparent);
    animation: urgency-glow 1.2s ease-in-out infinite;
  }
  .urgency-pill.show { display: inline-flex; }
  .urgency-pill.warmup {
    animation: none;
    background: linear-gradient(135deg, color-mix(in srgb, var(--warn) 22%, var(--panel)), var(--panel-2));
    border-color: color-mix(in srgb, var(--warn) 55%, var(--border));
    color: var(--warn);
    box-shadow: 0 0 12px color-mix(in srgb, var(--warn) 18%, transparent);
  }
  .urgency-pill.warmup #urgencyLbl { color: color-mix(in srgb, var(--warn) 80%, var(--text)); }
  .urgency-pill.ended { animation: none; opacity: .9; color: #ff8a94; border-color: color-mix(in srgb, var(--danger) 40%, var(--border)); background: var(--panel-2); box-shadow: none; }
  .urgency-pill #urgencyLbl { font-size: 8px; letter-spacing: .5px; opacity: .9; }
  .urgency-pill #urgencyTxt { font-size: 12px; }
  @keyframes urgency-glow { 0%,100%{ box-shadow: 0 0 12px color-mix(in srgb, var(--danger) 25%, transparent); } 50%{ box-shadow: 0 0 22px color-mix(in srgb, var(--danger) 50%, transparent); } }
  .screen { display: none; flex: 1; flex-direction: column; }
  .screen.active { display: flex; }
  .content { flex: 1; padding: 16px 16px calc(20px + var(--safe-b)); }
  .card {
    background: color-mix(in srgb, var(--panel) 92%, transparent);
    border: 1px solid var(--border); border-radius: 18px; padding: 18px;
    box-shadow: 0 16px 48px rgba(0,0,0,.35);
  }
  .card h2 { margin: 0 0 6px; font-size: 18px; }
  .sub { color: var(--text-dim); font-size: 13px; line-height: 1.55; margin: 0 0 14px; }
  .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
  .field label { font-size: 11px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; letter-spacing: .4px; }
  input {
    background: var(--bg-soft); border: 1px solid var(--border); color: var(--text);
    border-radius: 12px; padding: 12px 14px; font-size: 16px; font-family: var(--font); outline: none;
  }
  input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent); }
  .btn {
    cursor: pointer; border: none; border-radius: 12px; padding: 13px 18px; font-size: 15px; font-weight: 800;
    font-family: var(--font); background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #fff;
    width: 100%; margin-top: 6px;
  }
  .btn:disabled { opacity: .5; cursor: not-allowed; }
  .btn.ghost { background: transparent; color: var(--text-dim); border: 1px solid var(--border); margin-top: 10px; }
  .err { color: var(--danger); font-size: 12px; min-height: 18px; margin-top: 6px; }
  .hero { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
  .progress-ring { flex: none; width: 64px; height: 64px; }
  .progress-ring circle { fill: none; stroke-width: 5; stroke-linecap: round; transform: rotate(-90deg); transform-origin: 50% 50%; }
  .progress-ring .track { stroke: var(--border); }
  .progress-ring .fill { stroke: url(#grad); transition: stroke-dashoffset .5s ease; }
  .hero-mid { flex: 1; min-width: 0; }
  .hero-mid h1 { margin: 0; font-size: 20px; font-weight: 800; line-height: 1.15; }
  .hero-mid p { margin: 4px 0 0; font-size: 13px; color: var(--text-dim); }
  .hero .urgency-pill { flex: none; margin-left: auto; min-width: 72px; }
  .date-chip {
    display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700;
    padding: 6px 11px; border-radius: 99px; background: var(--panel-2); border: 1px solid var(--border);
    color: var(--accent-2); margin-bottom: 14px;
  }
  .ind-card {
    border: 1px solid var(--border); border-radius: 16px; padding: 14px; margin-bottom: 12px;
    background: var(--panel); position: relative; overflow: hidden;
  }
  .ind-card::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--ic);
  }
  .ind-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 12px; padding-left: 6px; }
  .ind-head b { font-size: 15px; color: var(--ic); }
  .ind-meta { font-size: 11px; color: var(--text-faint); font-weight: 700; }
  .dio-grid { display: grid; gap: 10px; }
  .dio-box {
    border-radius: 12px; padding: 10px 12px; border: 1.5px solid;
  }
  .dio-box.in { background: var(--dio-in-bg); border-color: var(--dio-in-bd); }
  .dio-box.out { background: var(--dio-out-bg); border-color: var(--dio-out-bd); }
  .dio-box.locked { opacity: .68; }
  .dio-box.mine { box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ok) 25%, transparent); }
  .dio-lbl { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .35px; margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
  .dio-box.in .dio-lbl { color: #7eb4ff; }
  .dio-box.out .dio-lbl { color: #5ee4b8; }
  .dio-box input {
    width: 100%; text-align: center; font-weight: 800; font-size: 18px; padding: 10px;
    background: color-mix(in srgb, var(--bg) 40%, transparent); border-radius: 10px; border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
  }
  .dio-box input:disabled { cursor: not-allowed; color: var(--text-dim); opacity: .75; }
  .dio-box.mine input { color: var(--text); opacity: 1; }
  .lock-tag {
    font-size: 9px; font-weight: 800; padding: 2px 7px; border-radius: 99px;
    background: color-mix(in srgb, var(--text-faint) 20%, transparent); color: var(--text-dim);
  }
  .lock-tag.gestor { background: color-mix(in srgb, var(--accent) 18%, transparent); color: var(--accent); }
  .lock-tag.consultor { background: color-mix(in srgb, var(--ok) 18%, transparent); color: var(--ok); }
  .lock-tag.soon { background: color-mix(in srgb, var(--warn) 22%, transparent); color: color-mix(in srgb, var(--warn) 85%, var(--text)); }
  .toast {
    position: fixed; bottom: calc(16px + var(--safe-b)); left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--panel-2); border: 1px solid var(--border); color: var(--text); padding: 11px 18px;
    border-radius: 99px; font-size: 13px; font-weight: 600; opacity: 0; transition: .3s; z-index: 100;
    box-shadow: 0 12px 40px rgba(0,0,0,.45); max-width: 90%; text-align: center;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .empty { text-align: center; color: var(--text-dim); padding: 32px 12px; font-size: 14px; line-height: 1.6; }
</style>
</head>
<body>
<div class="app">
  <header class="topbar">
    <div class="topbar-row">
      <div class="logo">GC</div>
      <div class="top-titles">
        <div class="t1">Gestão Alta Performance <span class="t1-sep">—</span> Meu Dia</div>
      </div>
      <div class="live-pill" id="livePill"><span class="dot"></span><span id="liveTxt">offline</span></div>
    </div>
  </header>

  <section class="screen active" id="screenLogin">
    <div class="content">
      <div class="card">
        <h2>Entrar</h2>
        <p class="sub">Use a <b>matrícula</b> e o <b>PIN</b> definidos pelo gestor em Regras de Negócio. Requer internet para sincronizar ao vivo.</p>
        <div class="field"><label>Loja</label><input id="inLoja" placeholder="VCANT" autocapitalize="characters" autocomplete="organization"></div>
        <div class="field"><label>Matrícula</label><input id="inMat" placeholder="Ex.: 10482" inputmode="numeric" autocomplete="username"></div>
        <div class="field"><label>PIN</label><input id="inPin" type="password" placeholder="••••" inputmode="numeric" maxlength="8" autocomplete="current-password"></div>
        <div class="err" id="loginErr"></div>
        <button class="btn" id="btnLogin">Acessar meu dia</button>
      </div>
    </div>
  </section>

  <section class="screen" id="screenMain">
    <div class="content">
      <div class="hero">
        <svg class="progress-ring" viewBox="0 0 64 64">
          <defs><linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#4f8cff"/><stop offset="100%" stop-color="#22d3aa"/></linearGradient></defs>
          <circle class="track" cx="32" cy="32" r="26"/>
          <circle class="fill" id="progArc" cx="32" cy="32" r="26" stroke-dasharray="163.36" stroke-dashoffset="163.36"/>
        </svg>
        <div class="hero-mid">
          <h1 id="helloName">—</h1>
          <p id="helloStore">—</p>
        </div>
        <div class="urgency-pill" id="urgencyPill"><span id="urgencyLbl">CHECK-OUT</span><span id="urgencyTxt">—:—:—</span></div>
      </div>
      <div class="date-chip" id="dateChip">—</div>
      <div id="fieldsRoot"></div>
      <button class="btn ghost" id="btnLogout">Sair</button>
    </div>
  </section>
</div>
<div class="toast" id="toast"></div>

<script>
"use strict";
const FIREBASE_CONFIG = {
  apiKey: "AIzaSyDZHUUAzhK5VDyrgpj4wcFJhrtMoJB2lnY",
  authDomain: "gestao-altaperformance.firebaseapp.com",
  databaseURL: "https://gestao-altaperformance-default-rtdb.firebaseio.com",
  projectId: "gestao-altaperformance",
  storageBucket: "gestao-altaperformance.firebasestorage.app",
  messagingSenderId: "943349612077",
  appId: "1:943349612077:web:2bc8cafbb06046df5ec2a4"
};
const SESSION_KEY = "gc_consultor_session";
const PBKDF2_ITER = 310000;
let fbDb = null, fbReady = false, connected = false;
let lojaData = null, lojaCode = "", seller = null, lojaListener = null;
let tickTimer = null, lastRenderDay = null, lastCheckoutOpen = null;
const CHECKOUT_OPEN = 16 * 60 + 30; // 16:30
const URGENCY_START = CHECKOUT_OPEN;
const URGENCY_END = 19 * 60 + 15;   // 19:15
function nowMins() {
  const n = new Date();
  return n.getHours() * 60 + n.getMinutes() + n.getSeconds() / 60;
}
function checkoutWindowOpen() { return nowMins() >= CHECKOUT_OPEN; }

const params = new URLSearchParams(location.search);
if (params.get("loja")) document.getElementById("inLoja").value = params.get("loja").toUpperCase();

function todayISO() { return new Date().toISOString().slice(0, 7); }
function todayDay() { return new Date().getDate(); }
function fmt(n) { return n == null || n === "" ? "—" : Number(n).toLocaleString("pt-BR"); }
function toast(msg, bad) {
  const el = document.getElementById("toast");
  el.textContent = msg;
  el.style.borderColor = bad ? "var(--danger)" : "var(--border)";
  el.classList.add("show");
  clearTimeout(toast._t);
  toast._t = setTimeout(() => el.classList.remove("show"), 2800);
}
function bytesToHex(buf) { return Array.from(buf).map(b => b.toString(16).padStart(2, "0")).join(""); }
function hexToBytes(hex) {
  const out = new Uint8Array(hex.length / 2);
  for (let i = 0; i < out.length; i++) out[i] = parseInt(hex.slice(i * 2, i * 2 + 2), 16);
  return out;
}
function timingSafeEqual(a, b) {
  if (!a || !b || a.length !== b.length) return false;
  let r = 0;
  for (let i = 0; i < a.length; i++) r |= a.charCodeAt(i) ^ b.charCodeAt(i);
  return r === 0;
}
async function verifyPin(pin, record) {
  if (!record || !record.hash || !record.salt) return false;
  const enc = new TextEncoder();
  const salt = hexToBytes(record.salt);
  const keyMaterial = await crypto.subtle.importKey("raw", enc.encode(pin), "PBKDF2", false, ["deriveBits"]);
  const bits = await crypto.subtle.deriveBits({ name: "PBKDF2", salt, iterations: PBKDF2_ITER, hash: "SHA-256" }, keyMaterial, 256);
  return timingSafeEqual(bytesToHex(new Uint8Array(bits)), record.hash);
}
function setLive(on, txt) {
  const pill = document.getElementById("livePill");
  pill.classList.toggle("on", on);
  document.getElementById("liveTxt").textContent = txt || (on ? "ao vivo" : "offline");
}
function showScreen(id) {
  document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
  document.getElementById(id).classList.add("active");
}
function saveSession() {
  localStorage.setItem(SESSION_KEY, JSON.stringify({
    loja: lojaCode, sellerId: seller.id, matricula: seller.matricula,
    exp: Date.now() + 7 * 24 * 60 * 60 * 1000
  }));
}
function loadSession() {
  try {
    const s = JSON.parse(localStorage.getItem(SESSION_KEY) || "null");
    if (!s || s.exp < Date.now()) return null;
    return s;
  } catch (e) { return null; }
}
function clearSession() { localStorage.removeItem(SESSION_KEY); }

function getCell(sellerId, fieldId, day, month) {
  const d = lojaData?.months?.[month]?.daily;
  return (d?.[sellerId]?.[fieldId]?.[day]) || {};
}
function cfgHasDiario(cfg) { return !!(cfg && (cfg.checkin || cfg.checkout)); }
function metaForDay(cfg, month, day) {
  const [y, mo] = month.split("-").map(Number);
  const wd = new Date(y, mo - 1, day).getDay();
  if (wd === 6) return Number(cfg.metaSat) || 0;
  if (wd === 0) return cfg.sundayOnly ? (Number(cfg.metaDay) || 0) : (Number(cfg.metaSun) || 0);
  return Number(cfg.metaDay) || 0;
}
function fieldList() {
  const list = [];
  (lojaData?.indicators || []).forEach(ind => {
    if (ind.pctOnly) return;
    if (cfgHasDiario(ind)) list.push({ cfg: ind, color: ind.color, sub: false });
    (ind.subs || []).filter(cfgHasDiario).forEach(s => list.push({ cfg: s, color: ind.color, sub: true }));
  });
  return list;
}
function hasCellValue(cell, key) {
  const v = cell[key];
  return v != null && v !== "";
}
function isViewingToday(day, month) {
  return month === todayISO() && day === todayDay();
}
/** Consultor: gestor trava sempre; check-out só após 16:30; próprio valor editável até 00:00 */
function cellLockedForConsultor(cell, key, day, month) {
  if (!isViewingToday(day, month)) return true;
  if (key === "real" && !checkoutWindowOpen()) return true;
  if (!hasCellValue(cell, key)) return false;
  if (cell[key + "By"] === "gestor") return true;
  return false;
}
function cellIsMine(cell, key) {
  return hasCellValue(cell, key) && cell[key + "By"] === "consultor";
}
function checkoutSoonLabel() {
  return '<span class="lock-tag soon">⏳ Libera em breve — veja o cronômetro</span>';
}
function lockLabel(cell, key, day, month) {
  if (key === "real" && !checkoutWindowOpen()) {
    if (cell[key + "By"] === "gestor") return '<span class="lock-tag gestor">👔 Gestor</span>';
    return checkoutSoonLabel();
  }
  if (!hasCellValue(cell, key)) return "";
  const by = cell[key + "By"];
  if (by === "gestor") return '<span class="lock-tag gestor">👔 Gestor</span>';
  if (by === "consultor") {
    if (!isViewingToday(day, month)) return '<span class="lock-tag">🔒 Dia encerrado</span>';
    return '<span class="lock-tag consultor">✎ Você · editável</span>';
  }
  return '<span class="lock-tag consultor">✎ Editável</span>';
}
function formatCountdown(ms) {
  if (ms <= 0) return "00:00:00";
  const t = Math.floor(ms / 1000);
  const h = Math.floor(t / 3600);
  const m = Math.floor((t % 3600) / 60);
  const s = t % 60;
  return [h, m, s].map(n => String(n).padStart(2, "0")).join(":");
}
function tickUrgencyAndDay() {
  const now = new Date();
  const mins = now.getHours() * 60 + now.getMinutes() + now.getSeconds() / 60;
  const pill = document.getElementById("urgencyPill");
  const txt = document.getElementById("urgencyTxt");
  const lbl = document.getElementById("urgencyLbl");
  if (!pill || !txt || !lbl) return;
  const onMain = document.getElementById("screenMain").classList.contains("active");
  pill.classList.remove("show", "ended", "warmup");
  if (onMain) {
    if (mins < URGENCY_START) {
      const start = new Date(now);
      start.setHours(16, 30, 0, 0);
      pill.classList.add("show", "warmup");
      lbl.textContent = "ABRE 16:30";
      txt.textContent = formatCountdown(Math.max(0, start - now));
    } else if (mins >= URGENCY_START && mins < URGENCY_END) {
      const end = new Date(now);
      end.setHours(19, 15, 0, 0);
      pill.classList.add("show");
      lbl.textContent = "⏱ CHECK-OUT";
      txt.textContent = formatCountdown(Math.max(0, end - now));
    } else {
      const midnight = new Date(now);
      midnight.setHours(24, 0, 0, 0);
      pill.classList.add("show", "ended");
      lbl.textContent = "ENCERRADO";
      txt.textContent = formatCountdown(Math.max(0, midnight - now));
    }
  }
  const d = todayDay();
  const coOpen = checkoutWindowOpen();
  if (onMain && lastCheckoutOpen !== null && coOpen !== lastCheckoutOpen) renderFields();
  lastCheckoutOpen = coOpen;
  if (lastRenderDay != null && d !== lastRenderDay && onMain) {
    renderFields();
    toast("Novo dia — ontem bloqueado");
  }
  lastRenderDay = d;
}
function startTickLoop() {
  lastRenderDay = todayDay();
  tickUrgencyAndDay();
  if (!tickTimer) tickTimer = setInterval(tickUrgencyAndDay, 1000);
}
function stopTickLoop() {
  if (tickTimer) { clearInterval(tickTimer); tickTimer = null; }
}
function countProgress() {
  const month = todayISO(), day = todayDay();
  let total = 0, done = 0;
  fieldList().forEach(({ cfg }) => {
    const c = getCell(seller.id, cfg.id, day, month);
    if (cfg.checkin) { total++; if (hasCellValue(c, "plan")) done++; }
    if (cfg.checkout) { total++; if (hasCellValue(c, "real")) done++; }
  });
  return { total, done };
}
function updateProgress() {
  const { total, done } = countProgress();
  const arc = document.getElementById("progArc");
  const circ = 163.36;
  const pct = total ? done / total : 0;
  arc.style.strokeDashoffset = String(circ * (1 - pct));
  document.getElementById("helloName").textContent = seller.name;
  const sn = (lojaData.storeName || lojaCode || "").trim();
  document.getElementById("helloStore").textContent = sn && sn.toUpperCase() !== lojaCode ? (lojaCode + " · " + sn) : lojaCode;
  const dt = new Date();
  document.getElementById("dateChip").textContent = dt.toLocaleDateString("pt-BR", { weekday: "short", day: "2-digit", month: "short", year: "numeric" });
}
function renderFields() {
  const root = document.getElementById("fieldsRoot");
  const month = todayISO(), day = todayDay();
  const fields = fieldList();
  if (!fields.length) {
    root.innerHTML = '<div class="empty">Nenhum indicador com check-in/out configurado.<br>O gestor precisa ativar em KPIs.</div>';
    return;
  }
  root.innerHTML = fields.map(({ cfg, color, sub }) => {
    const c = getCell(seller.id, cfg.id, day, month);
    const meta = metaForDay(cfg, month, day);
  const planLocked = cellLockedForConsultor(c, "plan", day, month);
  const realLocked = cellLockedForConsultor(c, "real", day, month);
  const planMine = cellIsMine(c, "plan");
  const realMine = cellIsMine(c, "real");
    let html = `<div class="ind-card" style="--ic:${color}"><div class="ind-head"><div><b>${sub ? "↳ " : ""}${cfg.name}</b><div class="ind-meta">Meta do dia: ${fmt(meta)}</div></div></div><div class="dio-grid">`;
    if (cfg.checkin) {
      html += `<div class="dio-box in${planLocked ? " locked" : ""}${planMine && !planLocked ? " mine" : ""}"><div class="dio-lbl">Check-in ${lockLabel(c, "plan", day, month)}</div>`;
      html += `<input type="number" inputmode="numeric" data-fid="${cfg.id}" data-key="plan" value="${c.plan ?? ""}" placeholder="—" ${planLocked ? "disabled" : ""}></div>`;
    }
    if (cfg.checkout) {
      html += `<div class="dio-box out${realLocked ? " locked" : ""}${realMine && !realLocked ? " mine" : ""}"><div class="dio-lbl">Check-out ${lockLabel(c, "real", day, month)}</div>`;
      html += `<input type="number" inputmode="numeric" data-fid="${cfg.id}" data-key="real" value="${c.real ?? ""}" placeholder="—" ${realLocked ? "disabled" : ""}></div>`;
    }
    html += "</div></div>";
    return html;
  }).join("");
  root.querySelectorAll("input[data-fid]").forEach(inp => {
    inp.addEventListener("change", () => saveField(inp));
    inp.addEventListener("keydown", e => { if (e.key === "Enter") { inp.blur(); } });
  });
  updateProgress();
  tickUrgencyAndDay();
}
async function saveField(inp) {
  if (!fbReady || !seller) return;
  const fieldId = inp.dataset.fid, key = inp.dataset.key;
  const month = todayISO(), day = todayDay();
  const val = inp.value.trim();
  if (val === "") return;
  const num = Number(val);
  if (isNaN(num)) { toast("Valor inválido", true); return; }
  const path = `lojas/${lojaCode}/data/months/${month}/daily/${seller.id}/${fieldId}/${day}`;
  const ref = fbDb.ref(path);
  try {
    if (key === "real" && !checkoutWindowOpen()) {
      toast("Check-out libera em breve — veja o cronômetro", true);
      renderFields();
      return;
    }
    const snap = await ref.once("value");
    const cell = snap.val() || {};
    if (cellLockedForConsultor(cell, key, day, month) && hasCellValue(cell, key)) {
      let msg = "Dia encerrado";
      if (cell[key + "By"] === "gestor") msg = "Preenchido pelo gestor — não pode alterar";
      else if (key === "real" && !checkoutWindowOpen()) msg = "Check-out libera em breve — veja o cronômetro";
      toast(msg, true);
      inp.value = cell[key] ?? "";
      renderFields();
      return;
    }
    await ref.update({ [key]: num, [key + "By"]: "consultor", [key + "At"]: Date.now() });
    await fbDb.ref("lojas/" + lojaCode).update({ updatedAt: Date.now() });
    toast("Salvo · sincronizado");
    renderFields();
  } catch (e) {
    console.warn(e);
    toast("Erro ao salvar. Verifique a conexão.", true);
  }
}
function attachLojaListener() {
  if (lojaListener) fbDb.ref("lojas/" + lojaCode).off("value", lojaListener);
  lojaListener = snap => {
    const v = snap.val();
    if (v && v.data) {
      lojaData = v.data;
      const s = (lojaData.sellers || []).find(x => x.id === seller.id);
      if (s) seller = s;
      if (document.getElementById("screenMain").classList.contains("active")) renderFields();
    }
  };
  fbDb.ref("lojas/" + lojaCode).on("value", lojaListener);
}
async function doLogin(loja, mat, pin) {
  const err = document.getElementById("loginErr");
  err.textContent = "";
  lojaCode = loja.toUpperCase().replace(/\s+/g, "");
  if (!/^VC[A-Z0-9]+$/.test(lojaCode) || lojaCode.length < 3) {
    err.textContent = "Código da loja inválido (ex.: VCANT).";
    return;
  }
  const matNorm = String(mat).trim();
  if (!matNorm) { err.textContent = "Informe a matrícula."; return; }
  if (!/^\d{4,8}$/.test(pin)) { err.textContent = "PIN deve ter 4 a 8 dígitos."; return; }
  if (!fbReady) { err.textContent = "Sem conexão com a nuvem. Tente novamente."; return; }
  err.textContent = "Verificando…";
  try {
    const snap = await fbDb.ref("lojas/" + lojaCode).once("value");
    const v = snap.val();
    if (!v || !v.data) { err.textContent = "Loja não encontrada ou sem dados na nuvem."; return; }
    lojaData = v.data;
    const found = (lojaData.sellers || []).find(s => String(s.matricula || "").trim() === matNorm);
    if (!found) { err.textContent = "Matrícula não encontrada nesta loja."; return; }
    if (!found.pinHash) { err.textContent = "PIN ainda não configurado. Peça ao gestor em Regras de Negócio."; return; }
    const ok = await verifyPin(pin, { hash: found.pinHash, salt: found.pinSalt });
    if (!ok) { err.textContent = "PIN incorreto."; return; }
    seller = found;
    saveSession();
    attachLojaListener();
    showScreen("screenMain");
    startTickLoop();
    renderFields();
    err.textContent = "";
  } catch (e) {
    console.warn(e);
    err.textContent = "Erro ao conectar. Verifique a internet.";
  }
}
async function tryRestore() {
  const s = loadSession();
  if (!s || !fbReady) return false;
  lojaCode = s.loja;
  try {
    const snap = await fbDb.ref("lojas/" + lojaCode).once("value");
    const v = snap.val();
    if (!v?.data) return false;
    lojaData = v.data;
    seller = (lojaData.sellers || []).find(x => x.id === s.sellerId);
    if (!seller) return false;
    attachLojaListener();
    showScreen("screenMain");
    startTickLoop();
    renderFields();
    return true;
  } catch (e) { return false; }
}
function fbInit() {
  try {
    firebase.initializeApp(FIREBASE_CONFIG);
    fbDb = firebase.database();
    firebase.auth().signInAnonymously().then(() => {
      fbReady = true;
      fbDb.ref(".info/connected").on("value", s => {
        connected = !!(s && s.val());
        setLive(connected, connected ? "ao vivo" : "conectando…");
      });
      startTickLoop();
      tryRestore().then(ok => { if (!ok) showScreen("screenLogin"); });
    }).catch(() => {
      setLive(false, "offline");
      document.getElementById("loginErr").textContent = "Não foi possível conectar. Verifique a internet.";
    });
  } catch (e) {
    setLive(false, "erro");
  }
}
document.getElementById("btnLogin").onclick = () => {
  doLogin(
    document.getElementById("inLoja").value,
    document.getElementById("inMat").value,
    document.getElementById("inPin").value
  );
};
["inLoja", "inMat", "inPin"].forEach(id => {
  document.getElementById(id).addEventListener("keydown", e => {
    if (e.key === "Enter") document.getElementById("btnLogin").click();
  });
});
document.getElementById("btnLogout").onclick = () => {
  if (lojaListener) { fbDb.ref("lojas/" + lojaCode).off("value", lojaListener); lojaListener = null; }
  stopTickLoop();
  clearSession(); seller = null; lojaData = null;
  document.getElementById("inPin").value = "";
  showScreen("screenLogin");
  toast("Sessão encerrada");
};
fbInit();
</script>
