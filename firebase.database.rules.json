{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null",
        ".write": false
      }
    },

    "auth": {
      ".read": "auth != null",
      ".write": false
    },

    "config": {
      "operational": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },

    "lojas": {
      "$lojaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
