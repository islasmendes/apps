{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null",
        ".write": false
      }
    },

    "auth": {
      ".read": "auth != null",
      ".write": false,
      "divisionais": {
        "$regional": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },

    "config": {
      "operational": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },

    "lojas": {
      "$lojaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "divisionais": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",
        "metas": {
          "$month": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    }
  }
}
