{
  "rules": {
    ".read": false,
    ".write": false,

    "lojas": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && (newData.exists() || root.child('admins').child(auth.uid).val() === true)"
      }
    },

    "admins": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null",
        ".write": "root.child('admins').child(auth.uid).val() === true"
      }
    },

    "auth": {
      ".read": "auth != null",
      ".write": "auth != null",
      "master": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "lojas": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },
      "divisionais": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },
      "adminDevices": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "config": {
      "operational": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      },
      "appBuild": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    "divisionais": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",
        "metas": {
          "$month": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    }
  }
}
