    if (c.plan != null && c.plan !== "" && !isNaN(Number(c.plan))) return Number(c.plan);
    const cross = crossPlanTarget(sellerId, cfg, day);
    return cross != null ? cross : null;
  }
  if (c.plan != null && c.plan !== "" && !isNaN(Number(c.plan))) return Number(c.plan);
  return null;
}
function visaoDiaDayRealValue(sellerId, fieldId, day) {
  const coId = visaoDiaResolveCheckoutFieldId(fieldId);
  const cfg = cfgById(coId);
  if (!cfg || day == null) return null;
  return diarioDayFieldOutValue(sellerId, cfg, day);
}
/** CVs com dia trabalhado antes de hoje — inclui folga hoje (checkout prox dia = plano de hoje na Visão Dia). */
function visaoDiaAgendamentoPlanSellers(day) {
  return orderedSellers().filter(s => prevWorkedDay(s.id, day) != null);
}
function visaoDiaAgendamentoTeamToday(card) {
  const day = diarioTodayDay();
  if (day == null) return { plan: null, real: null };
  const sellersToday = visaoDiaSellersToday();
  let plan = 0, planHas = false, real = 0, realHas = false;
  if (card.proxId) {
    visaoDiaAgendamentoPlanSellers(day).forEach(s => {
      const prev = prevWorkedDay(s.id, day);
      const v = visaoDiaDayRealValue(s.id, card.proxId, prev);
      if (v != null) { plan += v; planHas = true; }
    });
  }
  sellersToday.forEach(s => {
    if (card.realId) {
      const r = visaoDiaDayRealValue(s.id, card.realId, day);
      if (r != null) { real += r; realHas = true; }
    }
  });
  return { plan: planHas ? plan : null, real: realHas ? real : null };
}
function visaoDiaCardTodayValues(spec, card) {
  if (spec.kind === "agendamentoProx" || card.kind === "agendamentoProx") return visaoDiaAgendamentoTeamToday(card);
  return visaoDiaTeamTodayFields(card.planId, card.realId);
}
function visaoDiaTeamTodayFields(planId, realId) {
  const day = diarioTodayDay();
  if (day == null) return { plan: null, real: null };
  const sellers = visaoDiaSellersToday();
  let plan = 0, planHas = false, real = 0, realHas = false;
  sellers.forEach(s => {
    if (planId) {
      const p = visaoDiaDayPlanValue(s.id, planId, day);
      if (p != null) { plan += p; planHas = true; }
    }
    if (realId) {
      const r = visaoDiaDayRealValue(s.id, realId, day);
      if (r != null) { real += r; realHas = true; }
    }
  });
  return { plan: planHas ? plan : null, real: realHas ? real : null };
}
/** Projeção do mês (equipe) — mesma lógica da coluna Proj. da matriz (⌀ Equipe). */
function visaoDiaTeamProjPct(parentInd) {
