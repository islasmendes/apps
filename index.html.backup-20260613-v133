function writeFech(day, key, val) {
  const md = monthData();
  md.fechamento[day] = md.fechamento[day] || {};
  const had = fechHasData(day);
  if (val === '' || val == null || (typeof val === 'number' && isNaN(val))) delete md.fechamento[day][key];
  else md.fechamento[day][key] = val;
  if (!Object.keys(md.fechamento[day]).length) delete md.fechamento[day];
