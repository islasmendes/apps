// Grava loja na nuvem sem tocar em months.daily (check-in/out só via pushes granulares).
function buildLojaPushUpdates(code, st) {
  const updates = {};
  const ts = Date.now();
  updates[`lojas/${code}/name`] = st.storeName || code;
  updates[`lojas/${code}/code`] = code;
  updates[`lojas/${code}/updatedAt`] = ts;
  const data = JSON.parse(JSON.stringify(st));
  const months = data.months || {};
  delete data.months;
  Object.keys(data).forEach(k => { updates[`lojas/${code}/data/${k}`] = data[k]; });
  Object.keys(months).forEach(m => {
    const md = { ...months[m] };
    delete md.daily;
    Object.keys(md).forEach(mk => { updates[`lojas/${code}/data/months/${m}/${mk}`] = md[mk]; });
  });
  return updates;
}
function fbPush(opts){
  if (!fbReady || !fbDb || !lojaCode || divisionalMode()) return;
  clearTimeout(fbPushTimer);
  const skipMerge = !!(opts && opts.skipMerge);
  const delay = opts && opts.immediate ? 0 : 1200;
  fbPushTimer = setTimeout(async () => {
    try {
      if (!skipMerge) {
        const snap = await fbDb.ref("lojas/" + lojaCode + "/data/months").once("value");
        const remoteMonths = snap.val();
        if (remoteMonths) {
          const merged = mergeDailyFromRemote(remoteMonths);
          if (merged) refreshLiveDailyViews();
        }
      }
      const remoteSnap = await fbDb.ref("lojas/" + lojaCode + "/data").once("value");
      const remoteData = remoteSnap.val();
      const remoteRich = remoteData ? lojaStateRichness(migrate(remoteData)) : 0;
      const localRich = lojaStateRichness(state);
      if (remoteData && remoteRich > 25 && localRich < remoteRich * 0.45) {
        mergeLojaConfigFromSnapshot(state, migrate(remoteData), lojaCode);
      } else if (remoteData && lojaStateRichness(state) < lojaStateRichness(migrate(remoteData)) * 0.65) {
        mergeLojaConfigFromSnapshot(state, migrate(remoteData), lojaCode);
      }
      const localGuard = bestLocalSnapForLoja(lojaCode);
      if (localGuard && lojaStateRichness(state) < lojaStateRichness(localGuard) - 5) {
        mergeLojaConfigFromSnapshot(state, localGuard, lojaCode);
      }
      try { persistLocalState(state, lojaCode); } catch (e) { /* ignore */ }
      await fbDb.ref().update(buildLojaPushUpdates(lojaCode, state));
      publishAppBuild();
    } catch (e) { console.warn("push falhou", e); }
  }, delay);
}
