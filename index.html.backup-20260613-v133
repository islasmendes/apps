function acuracidadeFieldList() {
  const fields = [];
  state.indicators.forEach(ind => {
    if (ind.pctOnly) { (ind.rates||[]).forEach(r => { if (r.manual) fields.push({ id: "rate:"+r.id, rateId: r.id, name: r.name, color: ind.color, sub: false, rate: true }); }); return; }
    const hasCo = ind.checkout || (ind.subs || []).some(s => s.checkout);
    if (hasCo) fields.push({ id: ind.id, name: ind.name, color: ind.color, sub: false, rate: false });
  });
  return fields;
}
function fieldHasSistema(sellerId, f, m = currentMonth) {
  if (f.rate) return getSystemRate(sellerId, f.rateId, m) != null;
  return getSystem(sellerId, f.id, m) != null;
}
/** Célula/coluna na acuracidade: só quando o gestor lançou ⚙ para este vendedor. */
function acurFieldActive(sellerId, f, days, m = currentMonth) {
  return fieldHasSistema(sellerId, f, m);
}
/** Relato na acuracidade: check-out acumulado do CV (indicador principal — rollup do sub quando houver). */
function acurRelatoSum(sellerId, fieldId, days, m = currentMonth) {
  return checkoutSum(sellerId, fieldId, days, m);
}
function acuracidadeVisibleFields(sellers, allFields, days) {
  const d = days || monthDays();
  const list = allFields || acuracidadeFieldList().filter(f => !f.rate);
  const scope = (sellers && sellers.length) ? sellers : orderedSellers();
  return list.filter(f => scope.some(s => acurFieldActive(s.id, f, d)));
}
function acurTipRelato(f, rel, sys, acc) {
  const lines = [
    matrizDisplayName(f.name) + " (indicador principal)",
    "Relato CV (check-out acumulado): " + (rel != null ? fmt(rel) : "—"),
    "Gestor ⚙ (lançamento): " + (sys != null ? fmt(sys) : "—"),
  ];
  if (sys != null && acc != null) {
    lines.push("Acuracidade: " + pctTxt(acc) + (acc >= 0.95 ? " · excelente" : acc >= 0.5 ? " · atenção" : " · distante do gestor"));
    if (sys > 0 && rel != null) {
      const desv = Math.abs(rel - sys);
      lines.push("Desvio: " + fmt(desv) + " (" + pctTxt(desv / sys) + " do gestor)");
    } else if (sys === 0) lines.push("Gestor = 0 · relato " + (rel === 0 ? "bate" : "diverge"));
  }
  return lines.join("\n");
}
function acurRelatoCellHtml(sellerId, f, days) {
  const sys = getSystem(sellerId, f.id);
  if (sys == null) {
    return `<td class="relato muted"${matrizTipData(matrizDisplayName(f.name) + "\nSem lançamento ⚙ do gestor para este vendedor.", f.color)}>—</td>`;
  }
  const rel = acurRelatoSum(sellerId, f.id, days);
  const acc = fieldAccuracy(sellerId, f.id, days);
  const accColor = acc != null ? heatText(acc) : "var(--text-faint)";
  const relDisp = rel != null ? fmt(rel) : "—";
  const pctDisp = acc != null ? pctTxt(acc) : "—";
  const tip = acurTipRelato(f, rel, sys, acc);
  return `<td class="relato"${matrizTipData(tip, f.color)}>` +
    `<span class="acur-rel" style="color:${accColor}">${relDisp}</span>` +
    `<span class="acur-sep">/</span>` +
    `<span class="heat matriz-from-sys matriz-real acur-sys">${fmt(sys)}</span>` +
    `<span class="acur-pct" style="color:${accColor}">${pctDisp}</span></td>`;
}
function renderAcurLegend(targetId) {
  const el = document.getElementById(targetId || "acurLegend");
  if (!el) return;
  el.innerHTML =
    `<i><span class="sw" style="background:var(--danger)"></span> Acuracidade baixa (&lt;50%)</i>` +
    `<i><span class="sw" style="background:var(--warn)"></span> Atenção (50–94%)</i>` +
    `<i><span class="sw" style="background:var(--ok)"></span> Acurado (≥95%)</i>` +
    `<i><span class="heat matriz-from-sys matriz-real acur-sys" style="padding:1px 5px;font-size:10px;min-width:0">24</span> Gestor ⚙</i>` +
    `<i><span class="muted">—</span> Sem ⚙ do gestor = coluna oculta</i>`;
}
function fieldAccuracy(sellerId, fieldId, days) {
  const sys = getSystem(sellerId, fieldId);
  if (sys == null) return null;
  const r = acurRelatoSum(sellerId, fieldId, days) ?? 0;
  if (sys > 0) return Math.max(0, 1 - Math.abs(r - sys) / sys);
  return r === 0 ? 1 : 0;
}
