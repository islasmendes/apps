<script>
(function () {
  var BUILD = "v133";
  var FB = "https://gestao-altaperformance-default-rtdb.firebaseio.com/config/appBuild.json";
  function num(v) { var m = String(v || "").match(/(\d+)/); return m ? +m[1] : 0; }
  function clearJump() {
    try { Object.keys(sessionStorage).forEach(function (k) { if (k.indexOf("gc_jump_") === 0) sessionStorage.removeItem(k); }); } catch (e) {}
  }
  function norm(b) {
    var u = new URL(location.href);
    if (u.searchParams.get("v") !== b) { u.searchParams.set("v", b); history.replaceState(null, "", u.toString()); }
  }
  function jump(b) {
    if (num(b) <= num(BUILD)) return;
    var key = "gc_jump_" + b;
    var tries = +(sessionStorage.getItem(key) || 0);
    if (tries >= 6) return;
    sessionStorage.setItem(key, String(tries + 1));
    var u = new URL(location.href);
    u.searchParams.set("v", b);
    u.searchParams.set("_", String(Date.now()));
    location.replace(u.toString());
  }
  fetch(FB, { cache: "no-store" }).then(function (r) { return r.json(); }).then(function (remote) {
    if (!remote) { norm(BUILD); return; }
    if (num(remote) > num(BUILD)) jump(remote);
    else { clearJump(); norm(BUILD); }
  }).catch(function () { norm(BUILD); });
})();
</script>
