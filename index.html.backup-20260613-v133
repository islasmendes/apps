function switchToLoja(code) {
  const err = document.getElementById("lojaErr");
  if (err) err.textContent = "";
  const c = String(code || "").trim().toUpperCase().replace(/\s+/g, "");
  const okLoja = isLojaCode(c);
  const okDiv = isDivisionalCode(c);
  if (!okLoja && !okDiv) {
    if (err) err.textContent = "Use VC… (ex.: VCANT) ou RSCEN para o Divisional.";
    return false;
  }
  if (okDiv && divisionalMode() && c === divisionalCode) {
    document.getElementById("lojaModal")?.classList.remove("show");
    toast("Já está no Divisional");
    return true;
  }
  if (okLoja && !divisionalMode() && c === String(lojaCode || "").toUpperCase()) {
    document.getElementById("lojaModal")?.classList.remove("show");
    toast("Já está nesta loja");
    return true;
  }
  if (fbReady && lojaCode && !divisionalMode()) save({ skipConfigPush: true });
  document.getElementById("lojaModal")?.classList.remove("show");
  if (okDiv) {
    finishAuthEnterDivisional(c);
    toast("Modo Divisional ativo");
    return true;
  }
  if (lojaCode && authUnlocked && !divisionalMode()) persistLocalState(state, lojaCode);
  applyAuthContext("loja", c);
  if (authUnlocked) saveAuthSession({ type: "loja", code: c });
  resetLojaDataListener();
  const cloudOnly = localStateLojaTag() !== c;
  if (cloudOnly) resetLocalStateForLoja(c);
  fetchLojaDisplayName(c).then(displayName => {
    applyLojaIdentity(c, displayName);
    if (fbReady) pullLoja({ cloudOnly });
    else {
      save();
      syncStore();
      updateDivisionalNav();
      renderActive();
    }
    toast("Loja: " + displayName);
  });
  return true;
}
