function balanceDiarioTableLayout(table, dayCount) {
  if (!table || !dayCount) return;
  const cg = table.querySelector("colgroup");
  if (!cg) return;
  const nameCol = cg.querySelector(".dio-col-name");
  const metaCol = cg.querySelector(".dio-col-meta");
  const weekCols = [...cg.querySelectorAll(".dio-col-week")];
  const dayCols = [...cg.querySelectorAll(".dio-col-day")];
  if (!nameCol || !metaCol || !dayCols.length) return;
  table.style.tableLayout = "auto";
  const maxCellW = (sels, cap) => {
    let m = 0;
    (Array.isArray(sels) ? sels : [sels]).forEach(sel => {
      table.querySelectorAll(sel).forEach(el => { m = Math.max(m, el.scrollWidth || el.offsetWidth); });
    });
    const w = Math.ceil(m);
    return cap != null ? Math.min(w, cap) : w;
  };
  const nameW = Math.max(maxCellW("thead th.name"), 72);
  const metaW = Math.max(maxCellW("thead th.dio-meta-col", 72), 48);
  const weekW = Math.max(maxCellW("thead th.dio-week-col", 92), 56);
  nameCol.style.width = nameW + "px";
  metaCol.style.width = metaW + "px";
  weekCols.forEach(c => { c.style.width = weekW + "px"; });
  table.style.tableLayout = "fixed";
  const wrap = table.closest(".table-wrap");
  const tableW = Math.max((wrap && wrap.clientWidth) || table.clientWidth || 0, 480);
  const fixedW = nameW + metaW + weekW * weekCols.length;
  const remaining = Math.max(0, tableW - fixedW);
  const baseDayW = Math.max(72, Math.floor(remaining / dayCount));
  const slack = remaining - baseDayW * dayCount;
  dayCols.forEach((c, i) => {
    c.style.width = (baseDayW + (i === dayCols.length - 1 ? slack : 0)) + "px";
  });
}
