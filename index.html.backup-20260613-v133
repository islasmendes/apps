<script>
"use strict";
/* ============================================================
   Gestão Comercial — app de arquivo único, sem dependências.
   ============================================================ */
const LS_KEY = "gestao_comercial_v1";
const LS_STATE_LOJA_KEY = "gc_state_loja";
const uid = () => Math.random().toString(36).slice(2, 9);
const todayISO = () => new Date().toISOString().slice(0,7);

function defaultState() {
  const venda = uid(), fichas = uid(), agto = uid(), comp = uid(), troca = uid(), leads = uid(), nps = uid();
  const sFinEf = uid(), sTrocaEf = uid(), npsRate = uid();
  return {
    storeName: "VCANT", theme: "dark",
    sellers: [ { id: uid(), name: "Islas" }, { id: uid(), name: "Ana" } ],
    indicators: [
      { id: agto, name: "Agendamento", abbr: "AGTO", color: "#4f8cff", checkin: true, checkout: true, role: "", pctOnly: false, metaDay: 4, metaSat: 6, metaMonth: 96, subs: [], rates: [] },
      { id: comp, name: "Comparecimento", abbr: "COMP", color: "#22d3aa", checkin: false, checkout: true, role: "", pctOnly: false, metaDay: 2, metaSat: 4, metaMonth: 40, subs: [], rates: [] },
      { id: troca, name: "Carro Troca", abbr: "TROCA", color: "#a78bfa", checkin: false, checkout: true, role: "", pctOnly: false, metaDay: 1, metaSat: 2, metaMonth: 28,
        subs: [ { id: sTrocaEf, name: "Efetivação", checkin: false, checkout: true, metaDay: 0, metaSat: 0, metaSun: 0, metaMonth: 0 } ],
        rates: [ { id: uid(), name: "Pen%", numId: sTrocaEf, denId: venda, invert: false, target: 48, manual: false } ] },
      { id: fichas, name: "Financiamento", abbr: "FIN", color: "#ffb74d", checkin: true, checkout: true, role: "fichas", pctOnly: false, metaDay: 1, metaSat: 1, metaMonth: 24,
        subs: [ { id: sFinEf, name: "Efetivados", checkin: false, checkout: true, metaDay: 0, metaSat: 0, metaSun: 0, metaMonth: 0 } ],
        rates: [ { id: uid(), name: "Pen%", numId: sFinEf, denId: venda, invert: false, target: 45, manual: false } ] },
      { id: venda, name: "Vendas", abbr: "VENDA", color: "#46d39a", checkin: true, checkout: true, role: "venda", pctOnly: false, metaDay: 1, metaSat: 2, metaMonth: 14, subs: [], rates: [] },
      { id: leads, name: "Leads", abbr: "LEADS", color: "#38bdf8", checkin: false, checkout: true, role: "", pctOnly: false, metaDay: 2, metaSat: 2, metaMonth: 36, subs: [], rates: [] },
      { id: nps, name: "NPS", abbr: "NPS", color: "#f472b6", checkin: false, checkout: false, role: "", pctOnly: true, metaDay: 0, metaSat: 0, metaMonth: 0, subs: [],
        rates: [ { id: npsRate, name: "NPS", numId: "", denId: "", invert: false, target: 85, manual: true } ] },
    ],
    order: { sellers: null, indicators: null },
    ui: { view: "matriz", period: "mes", weekIdx: 0, diarioSeller: null, diarioWeek: 0, sistemaSeller: null, resumoWeek: 0, expanded: {} },
    months: {},
    consultorSchedule: {
      profiles: {
        weekday: {
          checkinOpen: "07:00",
          checkinClose: "12:00",
          checkinGraceEnd: "12:30",
          checkoutOpen: "16:00",
          checkoutClose: "20:00",
          checkoutGraceEnd: "20:30"
        },
        saturday: null,
        sunday: null,
        holiday: null
      },
      checkinOverride: null,
      checkoutOverride: null
    },
  };
}

let state = load();
function load() {
  const tag = localStateLojaTag();
  const cached = tag ? loadLocalStateSnapshot(tag) : null;
  if (cached) return cached;
  try { const raw = localStorage.getItem(LS_KEY); if (raw) return migrate(JSON.parse(raw)); }
  catch (e) { console.warn("load falhou", e); }
  return defaultState();
}
function localStateLojaTag() {
  return String(localStorage.getItem(LS_STATE_LOJA_KEY) || "").trim().toUpperCase();
}
function lojaLsKey(code) {
  const c = String(code || lojaCode || state?.storeName || "").trim().toUpperCase();
  if (/^VC[A-Z0-9]+$/.test(c) || /^RSCEN[A-Z0-9]*$/.test(c)) return `${LS_KEY}_${c}`;
  return LS_KEY;
}
function lojaLsBackupKey(code) {
  return `${lojaLsKey(code)}_backup`;
}
const LOJA_BACKUP_MAX = 15;
let _lastVersionedBackupKey = "";
function lojaBackupIndexKey(code) {
  return `${lojaLsKey(code)}_backups_index`;
}
function lojaBackupSlotKey(code, id) {
  return `${lojaLsKey(code)}_backup_${id}`;
}
function formatLojaBackupLabel(code, build, savedAt) {
  const c = String(code || lojaCode || "").trim().toUpperCase();
  const b = String(build || APP_BUILD || "v?").trim();
  const when = savedAt ? new Date(savedAt).toLocaleString("pt-BR", { day: "2-digit", month: "2-digit", year: "numeric", hour: "2-digit", minute: "2-digit" }) : "—";
  return `${c} BACKUP ${b} · ${when}`;
}
function readLojaBackupIndex(code) {
  const c = String(code || lojaCode || "").trim().toUpperCase();
  if (!c) return [];
  try {
    const raw = localStorage.getItem(lojaBackupIndexKey(c));
    const arr = raw ? JSON.parse(raw) : [];
    return Array.isArray(arr) ? arr : [];
  } catch (e) { return []; }
}
function writeLojaBackupIndex(code, index) {
  const c = String(code || lojaCode || "").trim().toUpperCase();
  if (!c) return;
  try { localStorage.setItem(lojaBackupIndexKey(c), JSON.stringify(index)); } catch (e) { /* quota */ }
}
function listLojaVersionedBackups(code) {
  migrateLegacyLojaBackup(code);
  const c = String(code || lojaCode || "").trim().toUpperCase();
  return readLojaBackupIndex(c).map(entry => ({
    ...entry,
    label: entry.label || formatLojaBackupLabel(c, entry.build, entry.savedAt)
  }));
}
function migrateLegacyLojaBackup(code) {
  const c = String(code || lojaCode || "").trim().toUpperCase();
  if (!c || readLojaBackupIndex(c).length) return;
  try {
    const raw = localStorage.getItem(lojaLsBackupKey(c));
    if (!raw) return;
    const snap = stampPersistLoja(migrate(JSON.parse(raw)), c);
    if (lojaStateRichness(snap) < 3) return;
    saveVersionedLojaBackup(snap, c, "legado-importado");
  } catch (e) { /* ignore */ }
}
function loadLojaVersionedBackup(code, id) {
  const c = String(code || lojaCode || "").trim().toUpperCase();
  if (!c || !id) return null;
  try {
    const raw = localStorage.getItem(lojaBackupSlotKey(c, id));
    if (!raw) return null;
    return stampPersistLoja(migrate(JSON.parse(raw)), c);
  } catch (e) { return null; }
}
function saveVersionedLojaBackup(st, code, reason) {
  const c = String(code || lojaCode || "").trim().toUpperCase();
  const bag = stampPersistLoja(st || state, c);
  if (!c || !bag || divisionalMode()) return null;
  const richness = lojaStateRichness(bag);
  if (richness < 3 && !(bag.sellers || []).length) return null;
  const id = `${String(APP_BUILD || "v0").replace(/[^a-zA-Z0-9]/g, "")}_${Date.now()}`;
  const entry = {
    id,
    label: formatLojaBackupLabel(c, APP_BUILD, Date.now()),
    build: APP_BUILD,
    loja: c,
    savedAt: Date.now(),
    reason: reason || "auto",
    richness,
    sellers: (bag.sellers || []).length,
    indicators: (bag.indicators || []).length
  };
  try {
    const payload = JSON.stringify(bag);
    localStorage.setItem(lojaBackupSlotKey(c, id), payload);
    const prev = localStorage.getItem(lojaLsKey(c));
    if (prev) localStorage.setItem(lojaLsBackupKey(c), prev);
    let index = readLojaBackupIndex(c);
    index = index.filter(e => e.id !== id);
