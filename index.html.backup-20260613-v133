  const who = focoSelectedSeller(sellers);
  const indIds = focoSelectedHistInds(focoMainIndicators());
  const c = focoChartColors();
  const { ctx, W, H } = setupCanvas(cv, 320);
  const pad = { l: 48, r: 14, t: 32, b: 56 };
  if (!who || !indIds.length) {
    ctx.fillStyle = c.dim; ctx.font = "13px sans-serif";
    ctx.fillText(!who ? "Cadastre consultores para ver o histórico." : "Selecione ao menos um indicador.", pad.l, H / 2);
    if (leg) leg.innerHTML = "";
    return;
  }
  const months = focoMonthsInRange(state.ui.focoHistYear, state.ui.focoHistFrom, state.ui.focoHistTo);
  if (!months.length) {
    ctx.fillStyle = c.dim; ctx.font = "13px sans-serif";
    ctx.fillText("Ajuste o período (ano e meses).", pad.l, H / 2);
    if (leg) leg.innerHTML = "";
    return;
  }
  const series = indIds.map(indId => {
    const ind = state.indicators.find(i => i.id === indId);
    const prevM = prevMonthKey(months[0]);
    let prevReal = getSellerMonthReal(who, indId, prevM);
    const points = months.map(m => {
      const close = getSellerMonthReal(who, indId, m) ?? 0;
      const open = prevReal != null ? prevReal : close;
      const ideal = focoIdealMetaMonth(who, indId, m);
      const high = Math.max(open, close, ideal);
      const low = Math.min(open, close);
      prevReal = close;
      return { m, label: monthShortLabel(m), open, close, high, low, ideal };
    });
    return { ind, points };
  });
  const allVals = series.flatMap(s => s.points.flatMap(p => [p.high, p.ideal]));
  const maxY = Math.max(...allVals, 1) * 1.12;
  const chartW = W - pad.l - pad.r;
  const nMonths = months.length;
  const nInds = series.length;
  const monthSlot = chartW / nMonths;
  const candleW = Math.min(18, Math.max(6, (monthSlot / nInds) * 0.65));
  const Y = v => H - pad.b - (H - pad.t - pad.b) * (v / maxY);
  ctx.strokeStyle = c.grid; ctx.fillStyle = c.dim; ctx.font = "11px sans-serif";
  for (let g = 0; g <= 4; g++) {
    const v = maxY * g / 4, y = Y(v);
    ctx.globalAlpha = .35; ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
    ctx.globalAlpha = 1; ctx.fillText(Math.round(v), 6, y + 4);
  }
  months.forEach((m, mi) => {
    const slotX = pad.l + monthSlot * mi;
    ctx.fillStyle = c.dim; ctx.font = "10px sans-serif"; ctx.textAlign = "center";
    ctx.fillText(monthShortLabel(m), slotX + monthSlot / 2, H - pad.b + 18);
    series.forEach((s, si) => {
      const p = s.points[mi];
      const cx = slotX + (monthSlot / (nInds + 1)) * (si + 1);
      drawFocoCandle(ctx, cx, p.open, p.close, p.high, p.low, Y, candleW, s.ind.color || c.ok, c.danger);
      if (p.ideal > 0) {
        const iy = Y(p.ideal);
        ctx.strokeStyle = c.dim; ctx.lineWidth = 1; ctx.setLineDash([3, 3]);
        ctx.beginPath(); ctx.moveTo(cx - candleW / 2 - 2, iy); ctx.lineTo(cx + candleW / 2 + 2, iy); ctx.stroke();
        ctx.setLineDash([]);
      }
      if (p.close > 0) {
        ctx.fillStyle = c.text; ctx.font = "bold 9px sans-serif"; ctx.textAlign = "center";
        ctx.fillText(Math.round(p.close), cx, Y(p.close) - 4);
      }
    });
  });
  const seller = state.sellers.find(s => s.id === who);
  const moShort = ["jan", "fev", "mar", "abr", "mai", "jun", "jul", "ago", "set", "out", "nov", "dez"];
  const pFrom = Math.min(state.ui.focoHistFrom, state.ui.focoHistTo);
  const pTo = Math.max(state.ui.focoHistFrom, state.ui.focoHistTo);
  const periodLbl = `${moShort[pFrom - 1]}–${moShort[pTo - 1]}/${String(state.ui.focoHistYear).slice(-2)}`;
  if (leg) leg.innerHTML =
    series.map(s => `<span><i style="background:${s.ind.color || c.accent}"></i> ${escapeHtml(s.ind.name)}</span>`).join("") +
    `<span><i style="background:transparent;border:1px dashed ${c.dim}"></i> Meta ideal</span>` +
    `<span class="muted">${escapeHtml(seller?.name || "—")} · ${periodLbl}</span>` +
    `<span class="muted">verde = subiu · vermelho = caiu vs mês anterior</span>`;
}
