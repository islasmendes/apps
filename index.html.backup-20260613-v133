function acurEquipeMetrics(sellerIds, fields, days) {
  let accSum = 0, accN = 0;
  fields.forEach(f => {
    if (!sellerIds.some(sid => acurFieldActive(sid, f, days))) return;
    const t = arvAcurTotalsForSellers(sellerIds, f, days);
    if (t.acc != null) { accSum += t.acc; accN++; }
  });
  let complete = 0, closed = 0, scheduled = 0, checkinDays = 0, checkoutDays = 0;
  sellerIds.forEach(sid => {
    const d = consultantDisciplineDetails(sid);
    complete += d.complete;
    closed += d.closed;
    scheduled += d.scheduled;
    checkinDays += d.checkinDays;
    checkoutDays += d.checkoutDays;
  });
  const ader = scheduled ? complete / scheduled : null;
  return { acc: accN ? accSum / accN : null, ader, disc: { complete, closed, scheduled, checkinDays, checkoutDays } };
}
function acurEquipeRowHtml(sellerIds, fields, days) {
  if (!sellerIds.length || !fields.length) return "";
