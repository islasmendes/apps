  const ids = matrizEquipeSellerIds();
  if (!ids.length) return null;
  const pack = matrizTeamProjPack(parentInd, ids, true);
  if (!pack || pack.pp == null) return null;
  return { pct: pack.pp, text: pctTxt(pack.pp) + " proj. mês", color: pack.color };
}
