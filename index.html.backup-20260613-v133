function pullLoja(opts) {
  opts = opts || {};
  const cloudOnly = !!opts.cloudOnly;
  if (!fbReady || !fbDb) return Promise.resolve(false);
  if (divisionalMode()) { pullDivisional(); return Promise.resolve(true); }
  if (!lojaCode) return Promise.resolve(false);
  const targetCode = String(lojaCode || "").trim().toUpperCase();
  const prevLoja = localStateLojaTag();
  if (!cloudOnly && prevLoja && state) persistLocalState(state, prevLoja);
  createLojaSafetyBackup(targetCode, "pre-pull");
  return fbDb.ref("lojas/" + lojaCode).once("value").then(snap => {
    const v = snap.val();
    const finish = () => {
      applyTheme(); applyTabOrder(); syncStore(); expandedBlocks = state.ui.expanded; arvExpandedBlocks = state.ui.arvExpanded || {};
      updateDivisionalNav();
      watchDivisionalMetas();
      renderActive(); startLojaDataListener();
      tryPromptOrphanRecovery();
      markLocalStateLoja(lojaCode);
      try { persistLocalState(state, targetCode); } catch (e) { /* ignore */ }
    };
    const mergePrefsFromSnaps = snaps => {
      snaps.filter(Boolean).forEach(s => mergeLojaConfigFromSnapshot(state, s, targetCode));
    };
    const finalizePull = (toastMsg) => {
      return pullDailyMonthsFromCloud(targetCode).then(remoteMonths => {
        if (remoteMonths) mergeDailyFromRemote(remoteMonths);
        const guardSnap = bestLocalSnapForLoja(targetCode);
        if (guardSnap && lojaStateRichness(state) < lojaStateRichness(guardSnap) - 5) {
          mergeLojaConfigFromSnapshot(state, guardSnap, targetCode);
        }
        applyMatrizShowUi(state);
        applyKpiTogglesUi(state);
        autoRecoverOrphanKpiData(state);
        save({ skipConfigPush: !isAdmin, skipPush: cloudOnly, immediatePush: !cloudOnly });
        finish();
        if (toastMsg) toast(toastMsg);
        return true;
      });
    };
    if (v && v.data) {
      const localVis = !cloudOnly && state?.ui?.matrizShow ? { ...state.ui.matrizShow } : null;
      const diskSnap = loadLocalStateSnapshot(targetCode);
      const localSnap = cloudOnly ? null : JSON.parse(JSON.stringify(state));
      const prePullSnap = cloudOnly ? JSON.parse(JSON.stringify(state)) : null;
      const bestLocal = bestLocalSnapForLoja(targetCode, diskSnap, localSnap, prePullSnap);
      const localToggles = !cloudOnly && state?.ui?.kpiToggles
        ? JSON.parse(JSON.stringify(state.ui.kpiToggles))
        : (bestLocal?.ui?.kpiToggles ? JSON.parse(JSON.stringify(bestLocal.ui.kpiToggles)) : null);
      const uiPrefs = cloudOnly ? { theme: state.theme, ui: { tabOrder: state.ui?.tabOrder, tabOrderAt: state.ui?.tabOrderAt } } : null;
      const cloudState = migrate(v.data);
      const cloudScore = lojaStateRichness(cloudState);
      const localScore = lojaStateRichness(bestLocal);
      if (bestLocal && localScore > cloudScore + 5) {
        state = migrate(JSON.parse(JSON.stringify(bestLocal)));
        stampPersistLoja(state, targetCode);
        mergeLojaConfigFromSnapshot(state, cloudState, targetCode);
      } else {
        state = cloudState;
        stampPersistLoja(state, targetCode);
        if (bestLocal) mergeLojaConfigFromSnapshot(state, bestLocal, targetCode);
      }
      if (cloudOnly && uiPrefs) mergeUiPrefsFromLocalState(state, uiPrefs);
      const cloudSnap = JSON.parse(JSON.stringify(state));
      if (localVis) state.ui.matrizShow = { ...(state.ui.matrizShow || {}), ...localVis };
      if (localToggles) state.ui.kpiToggles = { ...(state.ui.kpiToggles || {}), ...localToggles };
      applyMatrizShowUi(state);
      applyKpiTogglesUi(state);
      applyLojaIdentity(targetCode, lojaRemoteDisplayName(lojaCode, v, lojaCode));
      return applyTemplateFromCloud().then(() => {
        if (bestLocal) mergeLojaConfigFromSnapshot(state, bestLocal, targetCode);
        mergeDiarioDaysFromLocalState(state, cloudSnap);
        applyMatrizShowUi(state);
        applyKpiTogglesUi(state);
        return finalizePull(cloudOnly ? null : ("Loja " + lojaCode + " carregada da nuvem"));
      });
    }
    return fetchLojaDisplayName(lojaCode).then(displayName => {
      applyLojaIdentity(lojaCode, displayName);
      return applyTemplateFromCloud().then(() => finalizePull(cloudOnly ? null : ("Nova loja " + lojaCode + " criada")));
    });
  }).catch(e => { console.warn("pull falhou", e); return false; });
}
