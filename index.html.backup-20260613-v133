  const c = String(lojaCode).trim().toUpperCase();
  const tag = String(state._persistLoja || "").trim().toUpperCase();
  if (tag && tag !== c) return;
  const sn = String(state.storeName || "").trim();
  const snU = sn.toUpperCase();
  const wrongCode = /^VC[A-Z0-9]+$/.test(snU) && snU !== c;
  const generic = !sn || sn === "Loja" || sn === "Minha loja";
  if (generic || wrongCode) {
    fetchLojaDisplayName(c).then(displayName => applyLojaIdentity(c, displayName)).catch(() => applyLojaIdentity(c, c));
  } else {
    syncStoreNameUi();
  }
}
function adminLojaOptions() {
  const list = [], seen = new Set();
  const add = (code, label, opts) => {
    const c = String(code || "").trim().toUpperCase();
    if (!c || seen.has(c)) return;
    const ok = isLojaCode(c) || isDivisionalCode(c);
    if (!ok) return;
    seen.add(c);
    const active = opts?.active != null ? opts.active
      : (isDivisionalCode(c) ? divisionalMode() && c === divisionalCode : !divisionalMode() && c === String(lojaCode || "").toUpperCase());
    list.push({ code: c, label: label || c, active });
  };
  add("RSCEN", "RSCEN+ Divisional");
  Object.entries(remoteLojas || {}).forEach(([id, r]) => {
    if (!isRealLojaRemoteId(id, r)) return;
    const code = lojaCodeFromRemote(id, r);
    if (code) add(code, lojaRemoteDisplayName(id, r));
  });
  if (lojaCode) add(lojaCode, state.storeName || lojaCode);
  list.sort((a, b) => {
    if (a.code.startsWith("RSCEN")) return -1;
    if (b.code.startsWith("RSCEN")) return 1;
    if (a.active) return -1;
    if (b.active) return 1;
    return a.code.localeCompare(b.code, "pt-BR");
  });
  return list;
}
